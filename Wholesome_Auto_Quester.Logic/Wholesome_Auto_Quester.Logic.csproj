<?xml version="1.0" encoding="utf-8"?>
<!--
  Pure, WRobot-free decision logic for the Auto Quester (Phase 2 test seam).
  Classic (non-SDK) csproj on purpose: the VS BuildTools MSBuild that builds the product has no .NET SDK,
  so an SDK-style project here would fail to resolve. References NOTHING from wManager / robotManager, so it
  unit-tests fully offline. Both classic MSBuild (product) and `dotnet test` (tests) can build it.
-->
<Project ToolsVersion="4.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{7F3B2C1A-9D4E-4A8B-B6C2-1E2F3A4B5C6D}</ProjectGuid>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>Wholesome_Auto_Quester.Logic</RootNamespace>
    <AssemblyName>Wholesome_Auto_Quester.Logic</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="QuestChain.cs" />
    <Compile Include="QuestPrerequisites.cs" />
    <Compile Include="QuestStatus.cs" />
    <Compile Include="RecoveryPolicy.cs" />
    <Compile Include="QuestStatusLadder.cs" />
    <Compile Include="TaskPriority.cs" />
    <Compile Include="TaskValidity.cs" />
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
</Project>
